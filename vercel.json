{
  "version": 2,
  "builds": [
    {
      "src": "api/*.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    { "source": "/api/premarket", "destination": "/api/premarket.ts" },
    { "source": "/api/hyperliquid", "destination": "/api/hyperliquid.ts" },
    { "source": "/api/mexc", "destination": "/api/mexc.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}